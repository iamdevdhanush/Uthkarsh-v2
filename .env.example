# =============================================================================
# UTKARSH 26 — Registration Environment Configuration
# =============================================================================
# Copy this file to .env for local development:
#   cp .env.example .env
#
# For Vercel production deployment, set these exact names in:
#   Vercel Dashboard → Your Project → Settings → Environment Variables
# =============================================================================

# Registration mode: 'production' or 'mock'
#   mock        — Simulates submission locally (no external API required)
#   production  — Sends real data to Google Apps Script endpoint
# Defaults to 'mock' if unset.
VITE_REGISTRATION_MODE=mock

# Google Apps Script Web App URL (REQUIRED for production mode)
# 
# Deployment steps:
#   1. Open the target Google Sheet:
#      https://docs.google.com/spreadsheets/d/1eOHCwYnNT3dU4Ce2EQ9OMpJslfh7rVxClWoZr9Oj2_A
#
#   2. Extensions → Apps Script → paste apps-script/Code.gs content
#
#   3. Set Script Properties (File → Project properties → Script properties):
#      SPREADSHEET_ID = 1eOHCwYnNT3dU4Ce2EQ9OMpJslfh7rVxClWoZr9Oj2_A
#      DRIVE_FOLDER_ID = <Google Drive folder ID for payment screenshots>
#
#   4. Deploy → New deployment → Web App
#      Execute as: Me
#      Access: Anyone
#
#   5. Copy the Web App URL and paste below
#
# NOTE: This URL is public (Apps Script deployed as 'Anyone').
# Do NOT store API keys, service account credentials, or tokens here.
VITE_REGISTRATION_API_URL=
